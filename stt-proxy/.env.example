# Copy to .env and fill in. The .env file is gitignored.

# Free Groq API key from https://console.groq.com (no credit card required).
GROQ_API_KEY=

# Transcription model. Whisper-large-v3-turbo: best accuracy, ~200x real-time.
GROQ_MODEL=whisper-large-v3-turbo

# Origins allowed by CORS (the Vite dev server).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Port the proxy listens on.
PORT=8089
