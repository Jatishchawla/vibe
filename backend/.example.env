# Environment
NODE_ENV="production"
APP_PORT="3141"
APP_MODULE="auth"

# App
APP_URL="http://localhost:3141"
APP_ORIGINS="http://localhost:3141"

# Database
DB_URL="mongodb+srv://<username>:<password>@<remaining URI>"
DB_NAME="vibe"
MONGOMS_DEBUG="true"

# Firebase Emulators
FIREBASE_AUTH_EMULATOR_HOST="127.0.0.1:9099"
FIREBASE_EMULATOR_HOST="127.0.0.1:4000"
GCLOUD_PROJECT="example-project-id"

# Crowd Contributions (Phase 1) — AI question screening + similarity dedup
# Claude (judge). ANTHROPIC_CRED is the Anthropic API key; reused from config/ai.ts.
ANTHROPIC_CRED=""
CROWD_JUDGE_MODEL="claude-haiku-4-5"
CROWD_JUDGE_TIMEOUT_MS="8000"
# Voyage AI (embeddings for near-duplicate detection)
VOYAGE_API_KEY=""
VOYAGE_MODEL="voyage-3.5-lite"
VOYAGE_TIMEOUT_MS="2000"
# Dedup thresholds (cosine) + submit rate limit
CROWD_NEAR_DUP_THRESHOLD="0.92"
CROWD_HARD_DUP_THRESHOLD="0.985"
CROWD_RATE_WINDOW_MS="600000"
CROWD_RATE_MAX_PER_SEGMENT="5"
