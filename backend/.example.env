# Environment
NODE_ENV="production"
APP_PORT="3141"
APP_MODULE="auth"

# App
APP_URL="http://localhost:3141"
APP_ORIGINS="http://localhost:3141"

# Database
DB_URL="mongodb+srv://<username>:<password>@<remaining URI>"
DB_NAME="vibe"
MONGOMS_DEBUG="true"

# Firebase Emulators
FIREBASE_AUTH_EMULATOR_HOST="127.0.0.1:9099"
FIREBASE_EMULATOR_HOST="127.0.0.1:4000"
GCLOUD_PROJECT="example-project-id"

# ============================================================
# Crowd Contributions (Phase 1) — AI question screening + dedup
# Pick ONE provider set. Default = Google Gemini (free tier; one key powers BOTH
# the judge and embeddings). No vector DB needed — vectors live in MongoDB and
# are searched in-app (cosine).
# ============================================================

# --- Free cloud (recommended for demo): Google Gemini ---
# Get a free key (no credit card): https://aistudio.google.com/apikey
CROWD_LLM_PROVIDER="openai"
CROWD_LLM_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"
CROWD_LLM_API_KEY=""                       # <-- paste your Gemini API key
CROWD_JUDGE_MODEL="gemini-2.0-flash"
CROWD_EMBED_PROVIDER="openai"
CROWD_EMBED_MODEL="text-embedding-004"     # embeddings reuse the same key/base
CROWD_JUDGE_TIMEOUT_MS="12000"

# Dedup thresholds (cosine) + submit rate limit
CROWD_NEAR_DUP_THRESHOLD="0.92"
CROWD_HARD_DUP_THRESHOLD="0.985"
CROWD_RATE_WINDOW_MS="600000"
CROWD_RATE_MAX_PER_SEGMENT="5"

# --- Alternative A: Anthropic Claude + Voyage (paid) ---
# CROWD_LLM_PROVIDER="anthropic"
# ANTHROPIC_CRED=""                        # Anthropic API key (config/ai.ts)
# CROWD_JUDGE_MODEL="claude-haiku-4-5"
# CROWD_EMBED_PROVIDER="voyage"
# VOYAGE_API_KEY=""
# VOYAGE_MODEL="voyage-3.5-lite"

# --- Alternative B: fully local (Ollama, free/offline) ---
# Install Ollama, then: ollama pull llama3.1 && ollama pull nomic-embed-text
# CROWD_LLM_PROVIDER="ollama"
# CROWD_EMBED_PROVIDER="ollama"
# OLLAMA_BASE_URL="http://localhost:11434"
# CROWD_JUDGE_MODEL="llama3.1"
# CROWD_EMBED_MODEL="nomic-embed-text"
